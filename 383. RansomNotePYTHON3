class Solution:
    def canConstruct(self, ransomNote: str, magazine: str) -> bool:
        count = {}
        count_r = {}


        for i in magazine:
            if i in count:
                count[i] += 1
            else: 
                count[i] = 1
        
        for i in ransomNote:
            if i in count_r:
                count_r[i] += 1
            else:
                count_r[i] = 1
        
        for i in ransomNote:
            if i in count and i in count_r:
                if count_r[i] <= count[i]:
                    count[i] =count[i] - 1
                    count_r[i] =count_r[i] - 1
                    continue
            return False
        
        return True
