class Solution:
    def addStrings(self, num1: str, num2: str) -> str:

        carry = 0
        result = ""
        if len(num1) < len(num2):
            diff = len(num2) - len(num1)
            while diff:
                num1 = "0" + num1
                diff -=1
        if len(num2) < len (num1):
            diff = len(num1) - len(num2)
            while diff:
                num2 = "0" + num2
                diff -=1
        i = len(num1) -1
        j = len(num2) -1
        while i >= 0 or j >= 0:
            sum = int(num1[i]) + int(num2[i]) + carry
            result = str(sum % 10) + result
            carry = sum // 10
            i -= 1
            j -= 1
        
        if carry != 0 :
            return str(carry) + result 
        else:
             return result
