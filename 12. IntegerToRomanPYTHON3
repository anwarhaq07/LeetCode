class Solution:
    def intToRoman(self, num: int) -> str:
        
        result = ""

        while num > 0:

            if num > 999:
                temp = num//1000
                if temp == 3:
                    result+="MMM"
                elif temp == 2:
                    result+="MM"
                else:
                    result+="M"
                num = num % 1000
            if num > 99:
                temp = num//100
                if temp < 4:
                    while temp:
                        result+="C"
                        temp = temp - 1
                if temp == 4:
                    result+="CD"
                if temp > 4 and temp < 9:
                    result+="D"
                    temp = temp - 5
                    while temp:
                        result+="C"
                        temp = temp - 1
                if temp == 9:
                    result+="CM"
                num = num % 100
            if num > 9:
                temp = num//10
                if temp < 4:
                    while temp:
                        result+="X"
                        temp = temp - 1
                if temp == 4:
                    result+="XL"
                if temp > 4 and temp < 9:
                    result+="L"
                    temp = temp - 5
                    while temp:
                        result+="X"
                        temp = temp - 1
                if temp == 9:
                    result+="XC"
                num = num % 10
            if num < 10:
                temp = num//1
                if temp < 4:
                    while temp:
                        result+="I"
                        temp = temp - 1
                if temp == 4:
                    result+="IV"
                if temp > 4 and temp < 9:
                    result+="V"
                    temp = temp - 5
                    while temp:
                        result+="I"
                        temp = temp - 1
                if temp == 9:
                    result+="IX"
                num = 0

        return result       
