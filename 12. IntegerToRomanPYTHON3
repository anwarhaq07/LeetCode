class Solution:
    def intToRoman(self, num: int) -> str:
        
        result = ""

        while num > 0:

            if num > 999:
                temp = num//1000
                if temp == 3:
                    result+="MMM"
                elif temp == 2:
                    result+="MM"
                else:
                    result+="M"
                num = num % 1000
            if num > 99:
                temp = num//100
                result += self.helper(temp, "M", "D", "C")
                num = num % 100
            if num > 9:
                temp = num//10
                result += self.helper(temp, "C", "L", "X")
                num = num % 10
            if num < 10:
                temp = num//1
                result += self.helper(temp, "X", "V", "I")
                num = 0
        return result       

    def helper(self, digit:int, max:str, mid:str, min:str) -> str:
        result = ""
        if digit < 4:
            while digit:
                result+=min
                digit=digit-1
        if digit == 4:
            result+=(min+mid)
        if digit > 4 and digit<9:
            result+=mid
            digit = digit - 5
            while digit:
                result+=min
                digit = digit - 1
        if digit == 9:
            result +=(min+max)
        return result

