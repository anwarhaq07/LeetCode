class Logger:

    def __init__(self):
        self.my_dict = {}

    def shouldPrintMessage(self, timestamp: int, message: str) -> bool:
        if message not in self.my_dict:
            timestamp = timestamp + 10
            self.my_dict[message] = timestamp
            return True
        
        else:
            if self.my_dict[message] <= timestamp:
                self.my_dict[message] = timestamp+10
                return True
            else:
                return False


