class Solution:
    def checkPerfectNumber(self, num: int) -> bool:
        if num == 1:
            return False
        sq_root = floor(math.sqrt(num))
        i = 2
        sum = 1

        while i <= sq_root:
            if num % i == 0:
                div = num//i
                if div != num:
                    sum = div + i+sum
                else:
                    sum = sum +div
            elif sum > num:
                return False
            i+=1
        if sum == num:
            return True
        return False 


