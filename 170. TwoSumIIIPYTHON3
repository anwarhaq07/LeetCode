class TwoSum:

    def __init__(self):
        self.num = {}

    def add(self, number: int) -> None:
        if number not in self.num:
            self.num[number] = 1
        else:
            self.num[number] += 1

    def find(self, value: int) -> bool:
        for n in self.num:
            diff = value - n
            if diff in self.num and self.num[n] >=2:
                return True
            if diff in self.num and diff != n:
                return True
        return False


