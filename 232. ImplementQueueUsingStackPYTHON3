class MyQueue:

    def __init__(self):
        self.my_stack = []
        self.my_stack_out = []


    def push(self, x: int) -> None:
        self.my_stack.append(x)        

    def pop(self) -> int:
        if not self.my_stack_out:
            while self.my_stack:
                self.my_stack_out.append(self.my_stack.pop())
        return self.my_stack_out.pop()

    def peek(self) -> int:
        if not self.my_stack_out:
            while self.my_stack:
                self.my_stack_out.append(self.my_stack.pop())
        return self.my_stack_out[-1]

    def empty(self) -> bool:
        if not self.my_stack and not self.my_stack_out:
            return True
        else:
            return False


