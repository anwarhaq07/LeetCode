class Solution:
    def generatePossibleNextMoves(self, currentState: str) -> List[str]:
        
        output = []
        
        for i in range(len(currentState)-1):
            if currentState[i] == "+" and currentState[i+1] == "+":
                new_state = currentState[:i] + "--"+ currentState[i+2:]
                output.append(new_state)
        return output

