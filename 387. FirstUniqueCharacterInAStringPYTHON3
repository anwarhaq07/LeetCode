
############ NOT OPTOMAL##################

class Solution:
    def firstUniqChar(self, s: str) -> int:
        my_dict = {}

        for i in range(len(s)):
            for j in range((i+1),len(s)):
                if s[j] == s[i]:
                    my_dict[s[i]] = 1
            if s[i] not in my_dict:
                return i
        return -1

