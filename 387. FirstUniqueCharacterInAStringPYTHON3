class Solution:
    def firstUniqChar(self, s: str) -> int:
        my_dict = {}

        for i in s:
            if i not in my_dict:
                my_dict[i] = 1
            else:
                my_dict[i] += 1
        
        for index in range(len(s)):
            if my_dict[s[index]] <= 1:
                return index
        return -1
