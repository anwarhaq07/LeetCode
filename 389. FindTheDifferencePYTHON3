class Solution:
    def findTheDifference(self, s: str, t: str) -> str:
        sorted_s = ''.join(sorted(s))
        sorted_t = ''.join(sorted(t))

        for i, char in enumerate(s):
            if sorted_s[i] != sorted_t[i]:
                return sorted_t[i]
        
        return sorted_t[-1]
