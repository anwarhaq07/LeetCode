class Solution:
    def findComplement(self, num: int) -> int:
        n = num
        n_str = ""
        result = ""
        while num:
            if str(num%2) == "1":
                result = "0" +result
            else:
                result = "1"+result
            num = num//2
        
        return (int(result, 2))
