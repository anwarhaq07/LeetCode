class Solution:
    def constructRectangle(self, area: int) -> List[int]:
        sq_root = floor(math.sqrt(area))
        length = 0
        width = 0
        while sq_root>0:
            if area % sq_root == 0:
                length = sq_root
                width = area // length
                temp = length
                length = width
                width = temp
                break
            sq_root = sq_root - 1
        return [length, width]
