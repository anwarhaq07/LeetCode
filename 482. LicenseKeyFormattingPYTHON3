class Solution:
    def licenseKeyFormatting(self, s: str, k: int) -> str:
        s_len = len(s)-1 
        count = 0
        result = ""
        while s_len>=0:
            if s[s_len] != "-":
                result = s[s_len] + result
                count += 1

            if count == k:
                result = "-" + result
                count = 0

            s_len -= 1

            
        return result.upper().lstrip("-")
